---
// TeamGrid — Dot-divider label + heading + italic subtext + callout + member grid
//
// First card optionally renders an editable text input instead of a static name
// (enabled by default via `editableFirstCard`).
//
// Required CSS variables:
//   --color-bg
//   --color-ink
//   --color-white
//   --color-green-muted  divider lines + editable input underline
//   --color-green-dark   callout text color + editable input caret
//   --font-body, --weight-bold, --weight-regular
//   --tracking-tight
//   --leading-tight, --leading-snug
//   --text-base
//   --space-5, --space-10, --space-24
//   --gutter-mobile, --gutter-tablet, --gutter-desktop
//   --container-wide
//   --duration-fast, --ease-default

interface Member {
  name:   string;
  title:  string;
  photo:  string;
}

interface Props {
  label?:            string;
  heading?:          string;
  subtext?:          string;
  callout?:          string;
  members?:          Member[];
  editableFirstCard?: boolean;
}

const {
  label            = 'EL PROYECTO',
  heading          = 'El Equipo',
  subtext          = '"Ella no busca a los más sabios, sino a los que tienen fuego en el corazón".',
  callout          = 'Detrás de este proyecto hay profesionales unidos por una misión y un llamado.',
  members          = [
    { name: 'Escribe tu nombre aquí', title: 'Equipo Fundador',            photo: '/placeholder-member.jpg' },
    { name: 'Miembro 2',             title: 'Producción Cinematográfica',  photo: '/placeholder-member.jpg' },
    { name: 'Miembro 3',             title: 'Producción Cinematográfica',  photo: '/placeholder-member.jpg' },
    { name: 'Miembro 4',             title: 'Equipo Fundador',             photo: '/placeholder-member.jpg' },
  ],
  editableFirstCard = true,
} = Astro.props;

const [firstMember, ...restMembers] = members;
---

<section class="team-grid" aria-label={heading}>
  <div class="team-grid__container">

    <div class="team-grid__divider" aria-hidden="true">
      <span class="team-grid__divider-line"></span>
      <span class="team-grid__divider-label">{label}</span>
      <span class="team-grid__divider-line"></span>
    </div>

    <h2 class="team-grid__heading">{heading}</h2>

    <p class="team-grid__subtext">{subtext}</p>

    <p class="team-grid__callout">{callout}</p>

    <ul class="team-grid__list" role="list">

      <li class="team-grid__member">
        <div class="team-grid__photo">
          <img
            src={firstMember.photo}
            alt={editableFirstCard ? 'Tu lugar en el equipo' : firstMember.name}
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="team-grid__info">
          {editableFirstCard ? (
            <input
              class="team-grid__name team-grid__name--editable"
              type="text"
              placeholder={firstMember.name}
              aria-label="Tu nombre"
              maxlength="40"
            />
          ) : (
            <p class="team-grid__name">{firstMember.name}</p>
          )}
          <p class="team-grid__title">{firstMember.title}</p>
        </div>
      </li>

      {restMembers.map((m) => (
        <li class="team-grid__member">
          <div class="team-grid__photo">
            <img src={m.photo} alt={m.name} loading="lazy" decoding="async" />
          </div>
          <div class="team-grid__info">
            <p class="team-grid__name">{m.name}</p>
            <p class="team-grid__title">{m.title}</p>
          </div>
        </li>
      ))}

    </ul>

  </div>
</section>

<style>
  .team-grid {
    background-color: var(--color-bg);
    width: 100%;
    padding-block: var(--space-24);
  }

  .team-grid__container {
    width: 100%;
    max-width: var(--container-wide);
    margin-inline: auto;
    padding-inline: var(--gutter-mobile);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-10);
  }

  /* ── Divider ─────────────────────────────────────────────────────────── */
  .team-grid__divider {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    width: 100%;
  }

  .team-grid__divider-line {
    flex: 1;
    height: 1px;
    background-color: var(--color-green-muted);
    opacity: 0.5;
  }

  .team-grid__divider-label {
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: clamp(0.75rem, 0.5vw + 0.5rem, 1.125rem);
    color: var(--color-green-muted);
    letter-spacing: 0.5em;
    white-space: nowrap;
    text-transform: uppercase;
  }

  /* ── Heading ─────────────────────────────────────────────────────────── */
  .team-grid__heading {
    font-family: var(--font-body);
    font-weight: var(--weight-bold);
    font-size: clamp(2.5rem, 4vw + 1rem, 5rem);
    line-height: 1.05;
    color: var(--color-ink);
    text-align: center;
    margin: 0;
  }

  /* ── Italic subtext ──────────────────────────────────────────────────── */
  .team-grid__subtext {
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-style: italic;
    font-size: clamp(1rem, 0.8vw + 0.5rem, 1.5rem);
    line-height: 1.5;
    color: var(--color-ink);
    text-align: center;
    max-width: 860px;
    margin: 0;
  }

  /* ── Bold callout ────────────────────────────────────────────────────── */
  .team-grid__callout {
    font-family: var(--font-body);
    font-weight: var(--weight-bold);
    font-size: clamp(1.25rem, 1.5vw + 0.5rem, 2.5rem);
    line-height: 1.2;
    color: var(--color-green-dark);
    text-align: center;
    max-width: 865px;
    margin: 0;
    margin-bottom: var(--space-10);
  }

  /* ── Grid ────────────────────────────────────────────────────────────── */
  .team-grid__list {
    list-style: none;
    width: 100%;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
    margin: 0;
    padding: 0;
  }

  .team-grid__member {
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: calc(25% - 15px);
  }

  .team-grid__photo {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    border-radius: 500px 500px 20px 20px;
    overflow: hidden;
    background-color: #f0f0ee;
  }

  .team-grid__photo img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .team-grid__info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .team-grid__name {
    font-family: var(--font-body);
    font-weight: var(--weight-bold);
    font-size: clamp(0.9rem, 0.6vw + 0.6rem, 1.5rem);
    line-height: 1.3;
    color: var(--color-ink);
    margin: 0;
  }

  .team-grid__name--editable {
    appearance: none;
    background: transparent;
    border: none;
    border-bottom: 1.5px solid var(--color-green-muted);
    border-radius: 0;
    outline: none;
    width: 100%;
    padding: 0 0 2px;
    color: var(--color-ink);
    caret-color: var(--color-green-dark);
    transition: border-color var(--duration-fast) var(--ease-default);
  }

  .team-grid__name--editable::placeholder {
    color: var(--color-ink);
    opacity: 0.4;
    font-style: italic;
  }

  .team-grid__name--editable:focus { border-bottom-color: var(--color-green-dark); }

  .team-grid__title {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: clamp(0.75rem, 0.3vw + 0.5rem, 0.875rem);
    line-height: 1.4;
    color: var(--color-ink);
    opacity: 0.7;
    margin: 0;
  }

  @media (min-width: 768px)  { .team-grid__container { padding-inline: var(--gutter-tablet); } }
  @media (min-width: 1024px) { .team-grid__container { padding-inline: var(--gutter-desktop); } }

  @media (max-width: 1023px) { .team-grid__member { width: calc(50% - 10px); } }

  @media (max-width: 599px) {
    .team-grid__list   { gap: 12px; }
    .team-grid__member { width: calc(50% - 6px); }
  }
</style>
