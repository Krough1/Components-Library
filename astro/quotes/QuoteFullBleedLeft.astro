---
// QuoteFullBleedLeft — Full-bleed image, gradient left overlay, quote + body at bottom-left
//
// Required CSS variables:
//   --color-white
//   --font-display, --font-body, --weight-regular
//   --leading-loose
//   --space-6, --space-10, --space-24
//   --gutter-mobile, --gutter-tablet, --gutter-desktop
//   --container-wide

interface Props {
  imageSrc?:  string;
  quote?:     string;
  body?:      string;
}

const {
  imageSrc = '/placeholder-quote.jpg',
  quote    = '¿No estoy yo aquí, que soy tu Madre?',
  body     = 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor.',
} = Astro.props;
---

<section class="quote-left" aria-label="Cita">

  <img
    class="quote-left__bg"
    src={imageSrc}
    alt=""
    aria-hidden="true"
    loading="lazy"
    decoding="async"
  />

  <div class="quote-left__overlay" aria-hidden="true"></div>

  <div class="quote-left__container">
    <div class="quote-left__content">
      <blockquote class="quote-left__quote">{quote}</blockquote>
      <p class="quote-left__body">{body}</p>
    </div>
  </div>

</section>

<style>
  .quote-left {
    position: relative;
    width: 100%;
    min-height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  .quote-left__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .quote-left__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(63, 71, 66, 0.85) 0%,
      rgba(63, 71, 66, 0.85) 30%,
      rgba(102, 102, 102, 0) 65%
    );
    mix-blend-mode: multiply;
  }

  .quote-left__container {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--container-wide);
    margin-inline: auto;
    padding-inline: var(--gutter-mobile);
    padding-block: var(--space-24);
  }

  .quote-left__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
    max-width: 653px;
  }

  .quote-left__quote {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2.5rem, 3.5vw + 0.5rem, 3.75rem);
    line-height: 1.1;
    color: var(--color-white);
    margin: 0;
  }

  .quote-left__body {
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-style: italic;
    font-size: clamp(1rem, 1vw + 0.5rem, 1.25rem);
    line-height: var(--leading-loose);
    color: var(--color-white);
    max-width: 40ch;
  }

  @media (min-width: 768px)  { .quote-left__container { padding-inline: var(--gutter-tablet); } }
  @media (min-width: 1024px) { .quote-left__container { padding-inline: var(--gutter-desktop); } }

  @media (max-width: 767px) {
    .quote-left { min-height: 100vh; }

    .quote-left__overlay {
      background: linear-gradient(
        to bottom,
        rgba(63, 71, 66, 0.3) 0%,
        rgba(63, 71, 66, 0.85) 40%
      );
    }

    .quote-left__content {
      gap: var(--space-6);
      max-width: 100%;
    }
  }
</style>
