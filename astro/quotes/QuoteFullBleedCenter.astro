---
// QuoteFullBleedCenter — Full-bleed image, multiply color overlay, centered quote + attribution
//
// Required CSS variables:
//   --color-white
//   --color-green-dark   overlay color
//   --font-display, --font-body, --weight-regular
//   --leading-snug
//   --space-5, --space-24
//   --gutter-mobile, --gutter-tablet, --gutter-desktop
//   --container-wide

interface Props {
  imageSrc?:     string;
  quote?:        string;
  attribution?:  string;
}

const {
  imageSrc    = '/placeholder-quote.jpg',
  quote       = '"Ten por cierto que te lo agradeceré y lo recompensaré bien."',
  attribution = '— Source · Reference',
} = Astro.props;
---

<section class="quote-center" aria-label="Cita">

  <img
    class="quote-center__bg"
    src={imageSrc}
    alt=""
    aria-hidden="true"
    loading="lazy"
    decoding="async"
  />

  <div class="quote-center__overlay" aria-hidden="true"></div>

  <div class="quote-center__container">
    <div class="quote-center__content">
      <blockquote class="quote-center__quote">{quote}</blockquote>
      <p class="quote-center__attribution">{attribution}</p>
    </div>
  </div>

</section>

<style>
  .quote-center {
    position: relative;
    width: 100%;
    min-height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .quote-center__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .quote-center__overlay {
    position: absolute;
    inset: 0;
    background-color: var(--color-green-dark);
    mix-blend-mode: multiply;
  }

  .quote-center__container {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--container-wide);
    margin-inline: auto;
    padding-inline: var(--gutter-mobile);
    padding-block: var(--space-24);
  }

  .quote-center__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    text-align: center;
  }

  .quote-center__quote {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 3vw + 0.5rem, 3.75rem);
    line-height: 1.15;
    color: var(--color-white);
    margin: 0;
  }

  .quote-center__attribution {
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: clamp(1rem, 1vw + 0.4rem, 1.5rem);
    line-height: var(--leading-snug);
    color: var(--color-white);
  }

  @media (min-width: 768px)  { .quote-center__container { padding-inline: var(--gutter-tablet); } }
  @media (min-width: 1024px) { .quote-center__container { padding-inline: var(--gutter-desktop); } }
</style>
