---
// HeaderPill — Floating pill header, scroll-aware show/hide
//
// Hidden inside the hero section, slides in when scrolling UP past it,
// hides when scrolling DOWN. Mobile: collapses to hamburger + full-screen menu.
//
// Required CSS variables:
//   --color-ink          pill background
//   --color-white
//   --color-green-muted  nav links + burger bars + CTA bg
//   --font-body, --weight-regular
//   --text-base, --text-sm, --text-2xl, --text-lg, --text-xl
//   --tracking-wide
//   --radius-md, --radius-sm
//   --space-2, --space-3, --space-4, --space-5, --space-6, --space-8
//   --duration-base, --duration-fast
//   --ease-out, --ease-default
//   --z-sticky, --z-modal

interface NavLink {
  label: string;
  href:  string;
}

interface Props {
  logoSrc?:  string;
  logoAlt?:  string;
  navLinks?: NavLink[];
  ctaLabel?: string;
  ctaHref?:  string;
}

const {
  logoSrc  = '/placeholder-logo.png',
  logoAlt  = 'Logo',
  navLinks = [
    { label: 'Sección 1', href: '#section-1' },
    { label: 'Sección 2', href: '#section-2' },
    { label: 'Nosotros',  href: '/nosotros'  },
  ],
  ctaLabel = 'Quiero ser parte',
  ctaHref  = '#cta',
} = Astro.props;
---

<header class="site-header" id="site-header" aria-label="Navegación principal">
  <div class="site-header__inner">

    <!-- Logo -->
    <a href="/" class="site-header__logo" aria-label={`${logoAlt} — Inicio`}>
      <img src={logoSrc} alt={logoAlt} width="64" height="60" loading="eager" />
    </a>

    <!-- Desktop nav -->
    <nav class="site-header__nav" aria-label="Menú principal">
      <ul role="list" class="site-header__nav-list">
        {navLinks.map(({ label, href }) => (
          <li><a href={href} class="site-header__nav-link">{label}</a></li>
        ))}
      </ul>
    </nav>

    <!-- CTA button -->
    <a href={ctaHref} class="site-header__cta">{ctaLabel}</a>

    <!-- Mobile hamburger -->
    <button
      class="site-header__burger"
      id="nav-toggle"
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Abrir menú"
    >
      <span class="burger-bar"></span>
      <span class="burger-bar"></span>
      <span class="burger-bar"></span>
    </button>

  </div>
</header>

<!-- Mobile menu overlay -->
<div class="mobile-menu" id="mobile-menu" aria-hidden="true" role="dialog" aria-label="Menú de navegación">
  <button class="mobile-menu__close" id="nav-close" aria-label="Cerrar menú">✕</button>
  <nav aria-label="Menú móvil">
    <ul role="list" class="mobile-menu__list">
      {navLinks.map(({ label, href }) => (
        <li><a href={href} class="mobile-menu__link">{label}</a></li>
      ))}
    </ul>
    <a href={ctaHref} class="mobile-menu__cta">{ctaLabel}</a>
  </nav>
</div>

<script is:inline>
  (function () {
    const header    = document.getElementById('site-header');
    const toggle    = document.getElementById('nav-toggle');
    const close     = document.getElementById('nav-close');
    const menu      = document.getElementById('mobile-menu');
    const menuLinks = menu.querySelectorAll('.mobile-menu__link, .mobile-menu__cta');

    // ── Scroll behaviour ──────────────────────────────────────────────────
    let lastY   = 0;
    let heroH   = 0;
    let ticking = false;

    function heroHeight() {
      if (heroH) return heroH;
      const hero = document.querySelector('.hero, .hero-ns');
      heroH = hero ? hero.offsetHeight * 0.85 : window.innerHeight * 0.85;
      return heroH;
    }

    function updateHeader() {
      const y = window.scrollY;
      if (y < heroHeight()) {
        header.classList.remove('is-visible');
      } else if (y < lastY) {
        header.classList.add('is-visible');
      } else if (y > lastY) {
        header.classList.remove('is-visible');
      }
      lastY   = y;
      ticking = false;
    }

    window.addEventListener('scroll', function () {
      if (!ticking) { window.requestAnimationFrame(updateHeader); ticking = true; }
    }, { passive: true });

    window.addEventListener('resize', function () { heroH = 0; }, { passive: true });

    // ── Mobile menu ───────────────────────────────────────────────────────
    function openMenu() {
      menu.classList.add('is-open');
      menu.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      close.focus();
    }

    function closeMenu() {
      menu.classList.remove('is-open');
      menu.setAttribute('aria-hidden', 'true');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      toggle.focus();
    }

    toggle.addEventListener('click', openMenu);
    close.addEventListener('click', closeMenu);
    menuLinks.forEach(function (link) { link.addEventListener('click', closeMenu); });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && menu.classList.contains('is-open')) closeMenu();
    });
  })();
</script>

<style>
  /* ── Fixed pill wrapper ──────────────────────────────────────────────── */
  .site-header {
    position: fixed;
    top: var(--space-4);
    left: 50%;
    transform: translateX(-50%) translateY(calc(-100% - var(--space-4)));
    z-index: var(--z-sticky);
    width: calc(100% - var(--space-8));
    max-width: 1400px;
    transition: transform var(--duration-base) var(--ease-out),
                opacity  var(--duration-base) var(--ease-out);
    opacity: 0;
    pointer-events: none;
  }

  .site-header.is-visible {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Inner pill ──────────────────────────────────────────────────────── */
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background-color: var(--color-ink);
    border-radius: var(--radius-md);
    padding: 15px var(--space-5);
    gap: var(--space-4);
  }

  /* ── Logo ────────────────────────────────────────────────────────────── */
  .site-header__logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .site-header__logo img { height: 40px; width: auto; }

  /* ── Desktop nav ─────────────────────────────────────────────────────── */
  .site-header__nav-list {
    display: flex;
    gap: var(--space-2);
    list-style: none;
  }

  .site-header__nav-link {
    display: block;
    padding: var(--space-2);
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: var(--text-base);
    color: var(--color-green-muted);
    letter-spacing: var(--tracking-wide);
    white-space: nowrap;
    transition: color var(--duration-fast) var(--ease-default);
  }
  .site-header__nav-link:hover { color: var(--color-white); }

  /* ── CTA ─────────────────────────────────────────────────────────────── */
  .site-header__cta {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2) var(--space-5);
    background-color: var(--color-green-muted);
    color: var(--color-ink);
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: var(--text-base);
    border-radius: var(--radius-sm);
    white-space: nowrap;
    transition: background-color var(--duration-fast) var(--ease-default),
                color var(--duration-fast) var(--ease-default);
  }
  .site-header__cta:hover { background-color: var(--color-white); }

  /* ── Hamburger ───────────────────────────────────────────────────────── */
  .site-header__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    flex-shrink: 0;
  }

  .burger-bar {
    display: block;
    width: 22px;
    height: 2px;
    background-color: var(--color-green-muted);
    border-radius: 2px;
    transition: transform var(--duration-base) var(--ease-default),
                opacity   var(--duration-base) var(--ease-default);
  }

  /* ── Mobile menu overlay ─────────────────────────────────────────────── */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: var(--z-modal);
    background-color: var(--color-ink);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-8);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-8px);
    transition: opacity var(--duration-base) var(--ease-out),
                transform var(--duration-base) var(--ease-out);
  }

  .mobile-menu.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .mobile-menu__close {
    position: absolute;
    top: var(--space-6);
    right: var(--space-6);
    background: none;
    border: none;
    color: var(--color-green-muted);
    font-size: var(--text-xl);
    cursor: pointer;
    padding: var(--space-2);
  }

  .mobile-menu__list {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
    list-style: none;
  }

  .mobile-menu__link {
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: var(--text-2xl);
    color: var(--color-green-muted);
    letter-spacing: var(--tracking-wide);
    transition: color var(--duration-fast) var(--ease-default);
  }
  .mobile-menu__link:hover { color: var(--color-white); }

  .mobile-menu__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-8);
    background-color: var(--color-green-muted);
    color: var(--color-ink);
    font-family: var(--font-body);
    font-size: var(--text-lg);
    border-radius: var(--radius-sm);
  }

  /* ── Responsive ──────────────────────────────────────────────────────── */
  @media (max-width: 767px) {
    .site-header__nav, .site-header__cta { display: none; }
    .site-header__burger { display: flex; }
    .site-header { top: var(--space-3); width: calc(100% - var(--space-6)); }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .site-header__nav-link { font-size: var(--text-sm); }
    .site-header__cta { font-size: var(--text-sm); padding: var(--space-2) var(--space-4); }
  }
</style>
