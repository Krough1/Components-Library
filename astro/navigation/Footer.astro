---
// Footer — Dark background, brand column + N nav columns + social icons + copyright
//
// Required CSS variables:
//   --color-green-dark   background
//   --color-bg           text on dark (off-white)
//   --color-green-muted  headings, social icons, muted text
//   --color-white
//   --font-body, --weight-bold, --weight-regular
//   --text-base, --text-sm
//   --tracking-wider, --tracking-wide
//   --leading-snug
//   --space-2, --space-3, --space-5, --space-8, --space-10
//   --gutter-mobile, --gutter-tablet, --gutter-desktop
//   --container-wide
//   --duration-fast, --ease-default

interface NavLink  { label: string; href: string }
interface NavCol   { heading: string; links: NavLink[] }
interface Social   { label: string; href: string; icon: string }  // icon = 'instagram'|'facebook'|'youtube'

interface Props {
  logoSrc?:    string;
  logoAlt?:    string;
  brandName?:  string;
  brandSub?:   string;
  tagline?:    string;
  columns?:    NavCol[];
  socials?:    Social[];
  copyright?:  string;
}

const {
  logoSrc   = '/placeholder-logo.png',
  logoAlt   = 'Logo',
  brandName = 'BRAND',
  brandSub  = 'studios',
  tagline   = 'Your brand tagline goes here.',
  columns   = [
    { heading: 'SECCIÓN 1', links: [{ label: 'Link 1', href: '#' }, { label: 'Link 2', href: '#' }] },
    { heading: 'SECCIÓN 2', links: [{ label: 'Link 3', href: '#' }, { label: 'Link 4', href: '#' }] },
    { heading: 'SECCIÓN 3', links: [{ label: 'Link 5', href: '#' }, { label: 'Link 6', href: '#' }] },
  ],
  socials   = [
    { label: 'Instagram', href: '#', icon: 'instagram' },
    { label: 'Facebook',  href: '#', icon: 'facebook'  },
    { label: 'YouTube',   href: '#', icon: 'youtube'   },
  ],
  copyright = `© ${new Date().getFullYear()} Brand Name. All rights reserved.`,
} = Astro.props;
---

<footer class="site-footer" aria-label="Pie de página">
  <div class="site-footer__inner">

    <div class="site-footer__top">

      <!-- Brand column -->
      <div class="footer-brand">
        <a href="/" class="footer-brand__logo" aria-label={`${logoAlt} — Inicio`}>
          <img src={logoSrc} alt={logoAlt} width="64" height="60" />
          <span class="footer-brand__wordmark" aria-hidden="true">
            <span class="footer-brand__wordmark-name">{brandName}</span>
            <span class="footer-brand__wordmark-sub">{brandSub}</span>
          </span>
        </a>
        <p class="footer-brand__tagline">{tagline}</p>
        <p class="footer-brand__social-label">Síguenos en redes</p>
        <div class="footer-brand__socials">
          {socials.map(({ label, href, icon }) => (
            <a href={href} class="footer-social" aria-label={label}>
              {icon === 'instagram' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <circle cx="12" cy="12" r="4"/>
                  <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
                </svg>
              )}
              {icon === 'facebook' && (
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                </svg>
              )}
              {icon === 'youtube' && (
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.96-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
                  <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="white"/>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Nav columns -->
      {columns.map(({ heading, links }) => (
        <nav class="footer-nav" aria-label={heading}>
          <p class="footer-nav__heading">{heading}</p>
          <ul class="footer-nav__list" role="list">
            {links.map(({ label, href }) => (
              <li><a href={href} class="footer-nav__link">{label}</a></li>
            ))}
          </ul>
        </nav>
      ))}

    </div>

    <p class="site-footer__copy" set:html={copyright} />

  </div>
</footer>

<style>
  .site-footer { background-color: var(--color-green-dark); }

  .site-footer__inner {
    width: 100%;
    max-width: var(--container-wide);
    margin-inline: auto;
    padding-inline: var(--gutter-mobile);
    padding-block: var(--space-10);
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  .site-footer__top {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: var(--space-10);
    align-items: start;
  }

  /* ── Brand ───────────────────────────────────────────────────────────── */
  .footer-brand { display: flex; flex-direction: column; gap: var(--space-5); }

  .footer-brand__logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
  }

  .footer-brand__logo img { height: 60px; width: auto; flex-shrink: 0; }

  .footer-brand__wordmark { display: flex; flex-direction: column; line-height: 1; }

  .footer-brand__wordmark-name {
    font-family: var(--font-body);
    font-weight: var(--weight-bold);
    font-size: 1.125rem;
    color: var(--color-bg);
    letter-spacing: var(--tracking-wider);
  }

  .footer-brand__wordmark-sub {
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: 0.875rem;
    color: var(--color-green-muted);
    letter-spacing: 0.2em;
  }

  .footer-brand__tagline {
    font-family: var(--font-body);
    font-weight: var(--weight-bold);
    font-size: var(--text-base);
    color: var(--color-bg);
    line-height: var(--leading-snug);
    max-width: 28ch;
  }

  .footer-brand__social-label {
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: var(--text-base);
    color: var(--color-green-muted);
  }

  .footer-brand__socials { display: flex; gap: var(--space-2); }

  .footer-social {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background-color: var(--color-green-muted);
    color: var(--color-green-dark);
    transition: background-color var(--duration-fast) var(--ease-default);
  }
  .footer-social:hover { background-color: var(--color-white); }
  .footer-social svg { width: 15px; height: 15px; }

  /* ── Nav columns ─────────────────────────────────────────────────────── */
  .footer-nav { display: flex; flex-direction: column; gap: var(--space-2); }

  .footer-nav__heading {
    font-family: var(--font-body);
    font-weight: var(--weight-bold);
    font-size: clamp(0.85rem, 0.8vw + 0.4rem, 1.5rem);
    color: var(--color-green-muted);
    letter-spacing: var(--tracking-wide);
    padding: var(--space-2);
  }

  .footer-nav__list { display: flex; flex-direction: column; list-style: none; }

  .footer-nav__link {
    display: block;
    padding: var(--space-2);
    font-family: var(--font-body);
    font-weight: var(--weight-bold);
    font-size: clamp(0.8rem, 0.6vw + 0.5rem, 1.125rem);
    color: var(--color-bg);
    line-height: var(--leading-snug);
    transition: color var(--duration-fast) var(--ease-default);
  }
  .footer-nav__link:hover { color: var(--color-green-muted); }

  /* ── Copyright ───────────────────────────────────────────────────────── */
  .site-footer__copy {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: var(--text-sm);
    color: var(--color-bg);
    text-align: center;
    border-top: 1px solid rgba(238, 237, 237, 0.15);
    padding-top: var(--space-8);
  }

  /* ── Responsive ──────────────────────────────────────────────────────── */
  @media (min-width: 768px)  { .site-footer__inner { padding-inline: var(--gutter-tablet); } }
  @media (min-width: 1024px) { .site-footer__inner { padding-inline: var(--gutter-desktop); } }

  @media (max-width: 767px) {
    .site-footer__top { grid-template-columns: 1fr 1fr; gap: var(--space-8); }
    .footer-brand { grid-column: 1 / -1; }
    .footer-nav__link { white-space: normal; }
  }

  @media (max-width: 479px) {
    .site-footer__top { grid-template-columns: 1fr; }
  }
</style>
