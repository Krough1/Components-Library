---
// SectionOrnamentText — Centered ornament (flipped) + italic centered paragraphs
//
// Required CSS variables:
//   --color-bg
//   --color-ink
//   --font-body, --weight-regular
//   --space-6, --space-10, --space-24
//   --gutter-mobile, --gutter-tablet, --gutter-desktop
//   --container-wide

interface Props {
  ornamentSrc?:  string;
  paragraphs?:   string[];
}

const {
  ornamentSrc = '/placeholder-ornament.png',
  paragraphs  = [
    'Primer párrafo con texto en cursiva centrado.',
    'Segundo párrafo que continúa la narrativa.',
    'Tercer párrafo de cierre.',
  ],
} = Astro.props;
---

<section class="ornament-text" aria-label="Texto con ornamento">
  <div class="ornament-text__container">

    <div class="ornament-text__ornament" aria-hidden="true">
      <img
        src={ornamentSrc}
        alt=""
        width="98"
        height="100"
        loading="lazy"
        decoding="async"
      />
    </div>

    <div class="ornament-text__body">
      {paragraphs.map((p) => <p set:html={p} />)}
    </div>

  </div>
</section>

<style>
  .ornament-text {
    background-color: var(--color-bg);
    width: 100%;
    padding-block: var(--space-24);
  }

  .ornament-text__container {
    width: 100%;
    max-width: var(--container-wide);
    margin-inline: auto;
    padding-inline: var(--gutter-mobile);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-10);
  }

  .ornament-text__ornament img {
    display: block;
    height: clamp(64px, 7vw, 100px);
    width: auto;
    transform: scaleY(-1);
  }

  .ornament-text__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 650px;
    text-align: center;
  }

  .ornament-text__body p {
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-style: italic;
    font-size: clamp(1rem, 0.8vw + 0.6rem, 1.5rem);
    line-height: 1.65;
    color: var(--color-ink);
    margin: 0;
  }

  @media (min-width: 768px)  { .ornament-text__container { padding-inline: var(--gutter-tablet); } }
  @media (min-width: 1024px) { .ornament-text__container { padding-inline: var(--gutter-desktop); } }
</style>
