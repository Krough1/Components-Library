---
// PillTopCards — Three pill-top cards with modal + closing quote
//
// Cards use arch-top (pill) image + colored body. Middle card is "featured" (taller image).
// All card buttons open a single shared modal with image, heading, text, and CTA link.
//
// Required CSS variables:
//   --color-bg
//   --color-ink
//   --color-white
//   --color-green-muted  card 1 & 3 body bg
//   --color-green-dark   card 2 body bg, modal btn bg
//   --color-green-mid    button hover
//   --font-display, --font-body, --weight-bold, --weight-regular
//   --tracking-tight
//   --leading-tight, --leading-snug
//   --text-base
//   --space-2, --space-5, --space-12, --space-16, --space-20, --space-24
//   --gutter-mobile, --gutter-tablet, --gutter-desktop
//   --container-wide
//   --radius-sm
//   --duration-fast, --ease-default

interface Card {
  title:    string;
  desc:     string;
  imageSrc: string;
  imageAlt: string;
  btnLabel: string;
  featured?: boolean;
}

interface Props {
  heading?:        string;
  subtitle?:       string;
  cards?:          Card[];
  quote?:          string;
  modalImageSrc?:  string;
  modalHeading?:   string;
  modalText?:      string;
  modalCtaLabel?:  string;
  modalCtaHref?:   string;
}

const {
  heading       = '¿Y tú cómo quieres ser parte?',
  subtitle      = 'Elige la forma en que sientes el llamado. Cada acto suma.',
  cards         = [
    {
      title:    'Acción 1',
      desc:     'Descripción de la primera opción de participación.',
      imageSrc: '/placeholder-card-1.jpg',
      imageAlt: 'Imagen de la primera opción',
      btnLabel: 'Saber más',
    },
    {
      title:    'Acción 2',
      desc:     'Descripción de la segunda opción, la más destacada.',
      imageSrc: '/placeholder-card-2.jpg',
      imageAlt: 'Imagen de la segunda opción',
      btnLabel: 'Saber más',
      featured: true,
    },
    {
      title:    'Acción 3',
      desc:     'Descripción de la tercera opción de participación.',
      imageSrc: '/placeholder-card-3.jpg',
      imageAlt: 'Imagen de la tercera opción',
      btnLabel: 'Saber más',
    },
  ],
  quote         = '"Ella llegó hace 500 años con un mensaje para todos."',
  modalImageSrc = '/placeholder-modal.jpg',
  modalHeading  = '¡Gracias por tu interés!',
  modalText     = 'Estamos trabajando en esto. Regístrate para enterarte antes que nadie.',
  modalCtaLabel = 'Regístrarme',
  modalCtaHref  = '#',
} = Astro.props;
---

<section class="pill-cards" id="pill-cards" aria-labelledby="pill-cards-heading">
  <div class="pill-cards__container">

    <div class="pill-cards__title">
      <h2 class="pill-cards__heading" id="pill-cards-heading">{heading}</h2>
      <p class="pill-cards__subtitle">{subtitle}</p>
    </div>

    <div class="pill-cards__grid">
      {cards.map((card, i) => (
        <div class={`card ${i % 2 !== 0 ? 'card--dark card--featured' : 'card--muted'}`}>
          <div class={`card__image${card.featured ? ' card__image--tall' : ''}`}>
            <img
              src={card.imageSrc}
              alt={card.imageAlt}
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="card__body">
            <h3 class="card__title">{card.title}</h3>
            <p class="card__desc">{card.desc}</p>
            <div class="card__action">
              <button
                class={`card__btn js-open-modal ${i % 2 !== 0 ? 'card__btn--muted' : 'card__btn--dark'}`}
              >
                {card.btnLabel}
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>

    <p class="pill-cards__quote">{quote}</p>

  </div>
</section>

<dialog class="pc-modal" id="pc-modal" aria-labelledby="pc-modal-title">
  <div class="pc-modal__card">

    <button class="pc-modal__close" aria-label="Cerrar modal">&times;</button>

    <div class="pc-modal__image">
      <img src={modalImageSrc} alt="" loading="lazy" decoding="async" />
    </div>

    <div class="pc-modal__body">
      <h2 class="pc-modal__heading" id="pc-modal-title">{modalHeading}</h2>
      <p class="pc-modal__text">{modalText}</p>
      <a
        href={modalCtaHref}
        target="_blank"
        rel="noopener noreferrer"
        class="pc-modal__btn"
      >
        {modalCtaLabel}
      </a>
    </div>

  </div>
</dialog>

<script is:inline>
  (function () {
    var modal    = document.getElementById('pc-modal');
    var triggers = document.querySelectorAll('.js-open-modal');
    var closeBtn = modal.querySelector('.pc-modal__close');

    triggers.forEach(function (btn) {
      btn.addEventListener('click', function () { modal.showModal(); });
    });

    closeBtn.addEventListener('click', function () { modal.close(); });

    modal.addEventListener('click', function (e) {
      var rect = modal.querySelector('.pc-modal__card').getBoundingClientRect();
      var outside =
        e.clientX < rect.left  || e.clientX > rect.right ||
        e.clientY < rect.top   || e.clientY > rect.bottom;
      if (outside) modal.close();
    });
  })();
</script>

<style>
  .pill-cards {
    background-color: var(--color-bg);
    padding-block: var(--space-20) var(--space-24);
  }

  .pill-cards__container {
    width: 100%;
    max-width: var(--container-wide);
    margin-inline: auto;
    padding-inline: var(--gutter-mobile);
    display: flex;
    flex-direction: column;
    gap: var(--space-20);
  }

  /* ── Title ───────────────────────────────────────────────────────────── */
  .pill-cards__title {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    align-items: center;
    text-align: center;
  }

  .pill-cards__heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.5rem, 4vw + 1rem, 5rem);
    line-height: var(--leading-tight);
    color: var(--color-ink);
    max-width: 18ch;
  }

  .pill-cards__subtitle {
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: clamp(1rem, 1vw + 0.5rem, 1.5rem);
    line-height: var(--leading-snug);
    color: var(--color-ink);
  }

  /* ── Cards grid ──────────────────────────────────────────────────────── */
  .pill-cards__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    align-items: end;
  }

  .card {
    border-radius: 400px 400px 20px 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .card__image {
    height: 200px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .card__image--tall { height: 300px; }

  .card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .card__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 22px;
    padding: 20px;
  }

  .card--muted .card__body { background-color: var(--color-green-muted); }
  .card--dark  .card__body { background-color: var(--color-green-dark); }

  .card__title {
    font-family: var(--font-body);
    font-weight: var(--weight-bold);
    font-size: clamp(1.1rem, 1.2vw + 0.4rem, 1.5rem);
    color: var(--color-white);
    line-height: var(--leading-snug);
  }

  .card__desc {
    flex: 1;
    font-family: var(--font-body);
    font-weight: 300;
    font-size: clamp(0.9rem, 0.8vw + 0.4rem, 1.25rem);
    line-height: var(--leading-snug);
    color: var(--color-white);
  }

  .card__action {
    display: flex;
    justify-content: flex-end;
  }

  .card__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 41px;
    padding-inline: var(--space-5);
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: var(--text-base);
    border-radius: var(--radius-sm);
    border: none;
    appearance: none;
    white-space: nowrap;
    cursor: pointer;
    transition: background-color var(--duration-fast) var(--ease-default);
  }

  .card__btn--dark  { background-color: var(--color-green-dark); color: var(--color-bg); }
  .card__btn--dark:hover { background-color: var(--color-green-mid); }
  .card__btn--muted { background-color: var(--color-green-muted); color: var(--color-ink); }
  .card__btn--muted:hover { background-color: var(--color-green-dark); color: var(--color-white); }

  /* ── Closing quote ───────────────────────────────────────────────────── */
  .pill-cards__quote {
    font-family: var(--font-body);
    font-weight: var(--weight-bold);
    font-size: clamp(1.5rem, 2vw + 0.5rem, 2.5rem);
    line-height: var(--leading-snug);
    color: var(--color-green-dark);
    text-align: center;
  }

  @media (min-width: 768px)  { .pill-cards__container { padding-inline: var(--gutter-tablet); } }
  @media (min-width: 1024px) { .pill-cards__container { padding-inline: var(--gutter-desktop); } }

  @media (max-width: 767px) {
    .pill-cards { padding-block: var(--space-16) var(--space-20); }
    .pill-cards__container { gap: var(--space-12); }
    .pill-cards__grid { grid-template-columns: 1fr; }
    .card__image--tall { height: 200px; }
  }

  /* ── Modal ───────────────────────────────────────────────────────────── */
  .pc-modal {
    position: fixed;
    inset: 0;
    margin: auto;
    height: fit-content;
    border: none;
    padding: 0;
    background: transparent;
    max-width: 100%;
    width: 100%;
  }

  .pc-modal::backdrop {
    background: rgba(0, 0, 0, 0.72);
    backdrop-filter: blur(2px);
  }

  .pc-modal__card {
    position: relative;
    background: var(--color-white);
    border-radius: 20px;
    overflow: hidden;
    width: min(460px, calc(100vw - 32px));
    margin-inline: auto;
  }

  .pc-modal__close {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 10;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: none;
    background: rgba(0, 0, 0, 0.45);
    color: #fff;
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background var(--duration-fast) var(--ease-default);
  }

  .pc-modal__close:hover { background: rgba(0, 0, 0, 0.7); }

  .pc-modal__image {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .pc-modal__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .pc-modal__body {
    padding: 28px 24px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .pc-modal__heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.4rem, 6vw, 3.2rem);
    line-height: 1.05;
    color: var(--color-ink);
    letter-spacing: var(--tracking-tight);
  }

  .pc-modal__text {
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    line-height: 1.6;
    color: var(--color-ink);
  }

  .pc-modal__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 50px;
    background-color: var(--color-green-dark);
    color: var(--color-white);
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: var(--text-base);
    border-radius: var(--radius-sm);
    margin-top: 6px;
    transition: background-color var(--duration-fast) var(--ease-default);
  }

  .pc-modal__btn:hover { background-color: var(--color-green-mid); }
</style>
